<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1" />
  <meta name="color-scheme" content="only light" />
  <meta name="theme-color" content="#fcfcfc" />
  <title>Thoughts — Your Name</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
 
    :root {
      --bg: #fcfcfc;
      --text: #111;
      --muted: #666;
      --link: #111;
      --link-hover: #555;
      --border: #e5e5e5;
      --font-body: Georgia, 'Times New Roman', serif;
      --font-ui: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      --max-width: 680px;
      --side-pad: 2rem;
    }
 
    html, body {
      background: var(--bg);
      color: var(--text);
      font-family: var(--font-body);
      font-size: 16px;
      line-height: 1.75;
      -webkit-font-smoothing: antialiased;
      min-height: 100vh;
    }
 
    .page {
      max-width: var(--max-width);
      margin: 0 auto;
      padding: 3rem var(--side-pad) 6rem;
    }
 
    /* Nav */
    nav { margin-bottom: 3.5rem; }
 
    nav ul {
      list-style: none;
      display: flex;
      gap: 1.5rem;
      flex-wrap: wrap;
    }
 
    nav a {
      font-family: var(--font-ui);
      font-size: 14px;
      color: var(--muted);
      text-decoration: none;
      letter-spacing: 0.01em;
      transition: color 0.15s ease;
    }
 
    nav a:hover { color: var(--text); }
    nav a.active { color: var(--text); }
 
    /* Post list */
    .post-list {
      list-style: none;
    }
 
    .post-list li {
      border-bottom: 1px solid var(--border);
    }
 
    .post-list li:first-child {
      border-top: 1px solid var(--border);
    }
 
    .post-list a {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 1rem;
      padding: 0.75rem 0;
      text-decoration: none;
      color: var(--text);
      font-size: 15px;
      line-height: 1.5;
      transition: color 0.15s ease;
    }
 
    .post-list a:hover {
      color: var(--muted);
    }
 
    .post-title {
      flex: 1;
      min-width: 0;
    }
 
    .post-date {
      font-family: var(--font-ui);
      font-size: 13px;
      color: var(--muted);
      white-space: nowrap;
      flex-shrink: 0;
      letter-spacing: 0.02em;
    }
 
    @media (max-width: 600px) {
      :root { --side-pad: 1.25rem; }
      .page { padding-top: 2rem; }
 
      .post-list a {
        flex-direction: column;
        gap: 0.2rem;
      }
 
      .post-date { font-size: 12px; }
    }
  </style>
</head>
<body>
  <div class="page">
    <nav>
      <ul>
        <li><a href="index.html">About</a></li>
        <li><a href="thoughts.html" class="active">Thoughts</a></li>
        <li><a href="projects.html">Projects</a></li>
      </ul>
    </nav>
 
    <main>
      <ul class="post-list">
        <!--
          Add your posts here. Each item follows this pattern:
          <li>
            <a href="thoughts/post-slug.html">
              <span class="post-title">Post Title</span>
              <span class="post-date">YYYY.MM.DD</span>
            </a>
          </li>
        -->
        <li>
          <a href="#">
            <span class="post-title">Your Most Recent Post Title</span>
            <span class="post-date">2025.06.15</span>
          </a>
        </li>
        <li>
          <a href="#">
            <span class="post-title">Another Thought or Essay</span>
            <span class="post-date">2025.03.10</span>
          </a>
        </li>
        <li>
          <a href="#">
            <span class="post-title">An Older Post</span>
            <span class="post-date">2024.11.01</span>
          </a>
        </li>
        <li>
          <a href="#">
            <span class="post-title">Early Writing</span>
            <span class="post-date">2023.07.20</span>
          </a>
        </li>
      </ul>
    </main>
  </div>
</body>
</html>
 
